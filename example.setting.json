{
  "app_port": 3002,
  "log_level": "debug",
  "log_paths": {
    "app": "log",
    "echo": "log"
  },
  "static_db_path": "./static.db",
  "shutdown_timeout_seconds": 20,
  "cors": {
    "allow_origins": [
      "http://localhost:3000"
    ],
    "allow_credentials": true,
    "max_age": 3600
  },
  "database": {
    "pool": {
      "max_open_conns": 25,
      "max_idle_conns": 25,
      "conn_max_lifetime_sec": 300,
      "conn_max_idle_time_sec": 60
    }
  }
}